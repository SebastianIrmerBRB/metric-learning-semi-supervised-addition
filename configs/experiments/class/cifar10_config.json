{
  "save_dir": "cifar10",
  "dataset": "CIFAR10",
  "dataset_protocol": "cifar_balanced_fraction",
  "val_mode": "split_after_apportion",
  "cv_k": 4,
  "cv_mode": "stratified_kfold",
  "mode": "supervised",
  "length_before_new_iter": 10000,
  "ssl_config": "configs/ssl_faiss_knn.json",
  "hparam_config": "configs/supervised/classification/proxy_anchor.json",
  "label_budget_grid": [
    1
  ],
  "k_shot_grid": [4, 8, 16, 25, 50, 100, 250, 400],
  "ssl_label_sampling_modes": [
    "class_subset_k_shot"
  ],
  "loss_miner_grid": [
    "ProxyAnchorLoss:no_miner"
  ],
  "comparison_seeds": [
    7
  ]
}
