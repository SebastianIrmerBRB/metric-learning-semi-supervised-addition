    "lr": {
      "type": "float",
      "low": 1e-7,
      "high": 1e-5,
      "log": true
    },
   "ssl_config.method_params.regularizer_weight": {
      "type": "float", "low": 0.001, "high": 2, "log": true
    },
    "ssl_config.method_params.regularizer_params.reference_sets": {
      "type": "categorical",
      "choices": [1, 2]
    },
    "batch_sampler": {
      "type": "categorical",
      "choices": [
        "16:4",
        "32:4",
        "64:4",
        "128:4",
        "256:4",
        "256:8",
        "512:8"
      ]
    }
