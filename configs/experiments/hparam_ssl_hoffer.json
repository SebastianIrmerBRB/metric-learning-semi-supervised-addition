{
  "enabled": true,
  "n_trials": 60,
  "timeout": null,
  "direction": "maximize",
  "metric": "best_valid_mean_average_precision_at_r",
  "study_name": "mixed_label_cars_search",
  "study_dir": null,
  "storage": null,
  "load_if_exists": true,
  "sampler": "random",
  "sampler_params": {},
  "pruner": "none",
  "pruner_params": {},
