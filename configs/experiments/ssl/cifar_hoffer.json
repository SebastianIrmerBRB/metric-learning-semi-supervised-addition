{
  "enabled": true,
  "n_trials": 60,
  "timeout": null,
  "direction": "maximize",
  "metric": "best_valid_mean_average_precision_at_r",
  "study_name": "hoffer_entropy_search",
  "study_dir": null,
  "storage": null,
  "load_if_exists": true,
  "sampler": "random",
  "sampler_params": {},
  "pruner": "none",
  "pruner_params": {},
  "spaces": {
    "lr": {
      "type": "float",
      "low": 1e-7,
      "high": 1e-5,
      "log": true
    },
    "classifier_lr": {
      "type": "float",
      "low": 1e-4,
      "high": 1e+2,
      "log": true
    },
      "ssl_config.method_params.supervised_weight": {
      "type": "float",
      "low": 1,
      "high": 1,
      "log": true
    },
    "ssl_config.method_params.regularizer_weight": {
      "type": "float",
      "low": 0.001,
      "high": 10,
      "log": true
    },
    "ssl_config.method_params.regularizer_params.distance_scale": {
      "type": "float",
      "low": 0.25,
      "high": 16,
      "log": true
    },
    "ssl_config.method_params.regularizer_params.reference_sets": {
      "type": "categorical",
      "choices": [1, 2]
    },
    "loss.ArcFaceLoss.scale": {
      "type": "float",
      "low": 40,
      "high": 250.0,
      "log": true
    },
    "loss.ArcFaceLoss.margin": {
      "type": "float",
      "low": 15,
      "high": 30.0,
      "log": true
    },
    "loss.ProxyAnchorLoss.margin": {
      "type": "float",
      "low": 0.01,
      "high": 1.0,
      "log": true
    },
    "loss.MultiSimilarityLoss.alpha": {
      "type": "float",
      "low": 2,
      "high": 25,
      "log": true
    },
    "loss.MultiSimilarityLoss.beta": {
      "type": "float",
      "low": 40,
      "high": 100,
      "log": true
    },
    "loss.MultiSimilarityLoss.base": {
      "type": "float",
      "low": 0.4,
      "high": 0.9,
      "log": true
    },
    "loss.CircleLoss.m": {
      "type": "float",
      "low": 0.1,
      "high": 0.9,
      "log": true
    },
    "loss.CircleLoss.gamma": {
      "type": "float",
      "low": 50,
      "high": 260.0,
      "log": true
    },
    "loss.NTXentLoss.temperature": {
      "type": "float",
      "low": 0.0001,
      "high": 0.5,
      "log": true
    },
    "miner.MultiSimilarityMiner.epsilon": {
     "type": "float",
      "low": 0.1,
      "high": 0.8,
      "log": true
    },
    "batch_sampler": {
      "type": "categorical",
      "choices": [
        "16:8", "32:8", "64:8", "128:8", "256:8"
      ]
    }
  }
}
