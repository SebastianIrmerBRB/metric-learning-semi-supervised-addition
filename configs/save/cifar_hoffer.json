{
  "enabled": true,
  "n_trials": 60,
  "timeout": null,
  "direction": "maximize",
  "metric": "best_valid_mean_average_precision_at_r",
  "study_name": "hoffer_entropy_search",
  "study_dir": null,
  "storage": null,
  "load_if_exists": true,
  "sampler": "random",
  "sampler_params": {},
  "pruner": "none",
  "pruner_params": {},
  "spaces": {
    "lr": {
      "type": "float",
      "low": 1e-7,
      "high": 1e-5,
      "log": true
    },
    "classifier_lr": {
      "type": "float",
      "low": 1e-4,
      "high": 1e+2,
      "log": true
    },
      "ssl_config.method_params.supervised_weight": {
      "type": "float",
      "low": 0.1,
      "high": 2.0,
      "log": true
    },
    "ssl_config.method_params.regularizer_weight": {
      "type": "float",
      "low": 0.001,
      "high": 10,
      "log": true
    },
    "ssl_config.method_params.regularizer_params.distance_scale": {
      "type": "float",
      "low": 0.25,
      "high": 16,
      "log": true
    },
    "ssl_config.method_params.regularizer_params.num_compared": {
      "type": "categorical",
      "choices": [1, 2, 3]
    },
    "batch_sampler": {
      "type": "categorical",
      "choices": [
        "16:8", "32:8", "64:8", "128:8", "256:8"
      ]
    }
  }
}
