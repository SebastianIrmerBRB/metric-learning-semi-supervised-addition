{
  "enabled": true,
  "n_trials": 50,
  "timeout": null,
  "direction": "maximize",
  "metric": "best_valid_mean_average_precision_at_r",
  "study_name": "cifar10_k_shot_search",
  "study_dir": null,
  "storage": null,
  "load_if_exists": true,
  "sampler": "tpe",
  "sampler_params": {},
  "pruner": "none",
  "pruner_params": {},
