{
  "enabled": true,
  "n_trials": 60,
  "timeout": null,
  "direction": "maximize",
  "metric": "best_valid_mean_average_precision_at_r",
  "study_name": "cars_imb_search",
  "study_dir": null,
  "storage": null,
  "load_if_exists": true,
  "sampler": "random",
  "sampler_params": {},
  "pruner": "none",
  "pruner_params": {},
  "spaces": {
    "lr": {
      "type": "float",
      "low": 1e-7,
      "high": 1e-5,
      "log": true
    },
    "classifier_lr": {
      "type": "float",
      "low": 1e-4,
      "high": 1e+2,
      "log": true
    },
    "loss.ArcFaceLoss.scale": {
      "type": "float",
      "low": 40,
      "high": 250.0
    },
    "loss.ArcFaceLoss.margin": {
      "type": "float",
      "low": 15,
      "high": 30.0,
      "log": true
    },
    "loss.ProxyAnchorLoss.alpha": {
      "type": "float",
      "low": 0.1,
      "high": 100.0,
      "log": true
    },
    "loss.ProxyAnchorLoss.margin": {
      "type": "float",
      "low": 0.0001,
      "high": 1.0,
      "log": true
    },
    "loss.MultiSimilarityLoss.alpha": {
      "type": "float",
      "low": 2,
      "high": 25,
      "log": true
    },
    "loss.MultiSimilarityLoss.beta": {
      "type": "float",
      "low": 40,
      "high": 160,
      "log": true
    },
    "loss.MultiSimilarityLoss.base": {
      "type": "float",
      "low": 0.4,
      "high": 0.9,
      "log": true
    },
    "loss.CircleLoss.m": {
      "type": "float",
      "low": 0.1,
      "high": 0.9,
      "log": true
    },
    "loss.CircleLoss.gamma": {
      "type": "float",
      "low": 50,
      "high": 260.0,
      "log": true
    },
    "loss.NTXentLoss.temperature": {
      "type": "float",
      "low": 0.0001,
      "high": 0.5,
      "log": true
    },
    "miner.MultiSimilarityMiner.epsilon": {
     "type": "float",
      "low": 0.2,
      "high": 1,
      "log": true
    },
    "batch_sampler": {
      "type": "categorical",
      "choices": [
       "16:4", "32:4", "64:4", "128:4", "256:4", "512:8"
      ]
    }
